    .Modelica.Blocks.Sources.CombiTimeTable combiTimeTable_L1_Mechanical(startTime(displayUnit = "h") = 0,offset = {0},timeScale(displayUnit = "h") = 3600,extrapolation = .Modelica.Blocks.Types.Extrapolation.HoldLastPoint,smoothness = .Modelica.Blocks.Types.Smoothness.ConstantSegments,fileName = .ModelicaServices.ExternalReferences.loadResource("modelica://PrototypeBuildingElectricalModels/Data/LoadProfiles/San-Diego-Mechanical_LP.txt"),tableName = "Mechanical",tableOnFile = true) annotation(HideResult = true,Placement(transformation(extent = {{-38,74},{-18,94}},rotation = 0,origin = {0,0})));
    .Modelica.Blocks.Math.Gain gain(k = 0.95) annotation(HideResult = true,Placement(transformation(extent = {{10,78},{22,90}},rotation = 0,origin = {0,0})));
    inner .HPF.SystemDef systemDef annotation(Placement(transformation(extent = {{-132,76},{-104,100}},origin = {0,0},rotation = 0)));
    .HPF.SinglePhase.Components.Ground ground annotation(Placement(transformation(extent = {{2,-16},{18,0}},origin = {0,0},rotation = 0)));
    .HPF.PowerConverters.ThreePhase.ACDC_3pInverterSimple aCDC_3pInverterSimple(VAC_nom = 208) annotation(Placement(transformation(extent = {{-10.0,-10.0},{10.0,10.0}},origin = {-18.0,-28.0},rotation = -90.0)));
    .HPF.Sources.DC.FixedVoltage_VariablePower fixedVoltage_VariablePower(v_out = 600) annotation(Placement(transformation(extent = {{-10.0,-10.0},{10.0,10.0}},origin = {-18.0,-56.0},rotation = -180.0)));
    .HPF.DC.Ground ground2 annotation(Placement(transformation(extent = {{20,-58},{40,-38}},origin = {0,0},rotation = 0)));
equation
    connect(booleanConstant.y,voltageSource_outage.outage) annotation(Line(points = {{-77,26},{-63,26}},color = {255,0,255}));
    connect(gain.y,realToComplex2.im) annotation(Line(points = {{22.6,84},{26,84},{26,78},{30,78},{30,80},{33,80}},color = {0,0,127}));
    connect(gain.u,realToComplex2.re) annotation(Line(points = {{8.8,84},{6,84},{6,104},{28,104},{28,86},{33,86}},color = {0,0,127}));
    connect(combiTimeTable_L1_Mechanical.y[1],gain.u) annotation(Line(points = {{-17,84},{8.8,84}},color = {0,0,127}));
    connect(realToComplex2.y,aC_LoadIdeal1P.S_input) annotation(Line(points = {{44.5,83},{92.2,83},{92.2,49}},color = {160,160,164}));
    connect(voltageSource_outage.pinP_phA,R3.pin_p) annotation(Line(points = {{-42,30},{-6,30},{-6,60},{30,60}},color = {92,53,102}));
    connect(voltageSource_outage.pinP_phB,R2.pin_p) annotation(Line(points = {{-42,22},{-13,22},{-13,46},{16,46}},color = {92,53,102}));
    connect(voltageSource_outage.pinP_phC,R.pin_p) annotation(Line(points = {{-42,14},{-20,14},{-20,32},{2,32}},color = {92,53,102}));
    connect(voltageSource_outage.pinP_phA,aC_LoadIdeal1P.hPin_L) annotation(Line(points = {{-42,30},{20,30},{20,44},{82,44}},color = {92,53,102}));
