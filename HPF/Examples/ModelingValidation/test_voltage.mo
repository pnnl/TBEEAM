    connect(R2.pin_n,ground.pin) annotation(Line(points = {{36,46},{42,46},{42,6},{10,6},{10,0}},color = {117,80,123}));
    connect(R.pin_n,ground.pin) annotation(Line(points = {{22,32},{28,32},{28,6},{10,6},{10,0}},color = {117,80,123}));
    connect(aC_LoadIdeal1P.hPin_N,ground.pin) annotation(Line(points = {{102,44},{108,44},{108,6},{10,6},{10,0}},color = {117,80,123}));
    connect(voltageSource_outage.pinN,ground.pin) annotation(Line(points = {{-52,12},{-52,6},{10,6},{10,0}},color = {117,80,123}));
    connect(aCDC_3pInverterSimple.pin_p,fixedVoltage_VariablePower.p) annotation(Line(points = {{-9.999999999999998,-38},{-9.999999999999998,-44},{-2,-44},{-2,-56},{-8,-56}},color = {0,0,255}));
    connect(aCDC_3pInverterSimple.pin_n,fixedVoltage_VariablePower.n) annotation(Line(points = {{-26,-38},{-26,-44},{-34,-44},{-34,-56},{-28,-56}},color = {0,0,255}));
    connect(combiTimeTable_L1_Mechanical.y[1],fixedVoltage_VariablePower.p_out) annotation(Line(points = {{-17,84},{-2,84},{-2,-70},{-18,-70},{-18,-64}},color = {0,0,127}));
    connect(voltageSource_outage.pinP_phA,aCDC_3pInverterSimple.hPin_A) annotation(Line(points = {{-42,30},{-10.000000000000002,30},{-10.000000000000002,-18}},color = {92,53,102}));
    connect(aCDC_3pInverterSimple.hPin_B,voltageSource_outage.pinP_phB) annotation(Line(points = {{-15.000000000000002,-18},{-15.000000000000002,22},{-42,22}},color = {92,53,102}));
    connect(voltageSource_outage.pinP_phC,aCDC_3pInverterSimple.hPin_C) annotation(Line(points = {{-42,14},{-20.000000000000004,14},{-20.000000000000004,-18}},color = {92,53,102}));
    connect(aCDC_3pInverterSimple.hPin_N,ground.pin) annotation(Line(points = {{-26,-18},{-26,6},{10,6},{10,0}},color = {117,80,123}));
    connect(fixedVoltage_VariablePower.n,ground2.p) annotation(Line(points = {{-28,-56},{-34,-56},{-34,-32},{30,-32},{30,-38}},color = {0,0,255}));
    annotation(Icon(coordinateSystem(preserveAspectRatio = false,extent = {{-100.0,-100.0},{100.0,100.0}}),graphics = {Rectangle(lineColor={0,0,0},fillColor={230,230,230},fillPattern=FillPattern.Solid,extent={{-100.0,-100.0},{100.0,100.0}}),Text(lineColor={0,0,255},extent={{-150,150},{150,110}},textString="%name")}));
end test_voltage;
