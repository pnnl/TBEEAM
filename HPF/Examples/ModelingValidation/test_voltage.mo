within HPF.Examples.ModelingValidation;
model test_voltage
    .HPF.Sources.ThreePhase.VoltageSource_outage voltageSource_outage annotation(Placement(transformation(extent = {{-62.0,12.0},{-42.0,32.0}},origin = {0.0,0.0},rotation = 0.0)));
